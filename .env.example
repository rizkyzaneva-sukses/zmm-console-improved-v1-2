# ─────────────────────────────────────────────────────────────
# ZMM Console — Environment Variables
# Copy file ini jadi .env.local untuk development
# Di EasyPanel: isi via menu Environment Variables
# ─────────────────────────────────────────────────────────────

# ── DATABASE ──────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# EasyPanel: ganti HOST dengan nama service PostgreSQL
DATABASE_URL="postgresql://zmm_user:your_password@postgres:5432/zmm_db"

# ── NEXTAUTH ──────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="ganti_dengan_random_string_panjang_minimal_32_karakter"
NEXTAUTH_URL="https://your-domain.com"  # development: http://localhost:3000
APP_URL="https://your-domain.com" # opsional, dipakai untuk callback OAuth jika ingin eksplisit

# ── ENCRYPTION ────────────────────────────────────────────────
# Untuk enkripsi access_token & refresh_token Shopee/TikTok di DB
# WAJIB 32 karakter (AES-256)
# Generate: openssl rand -hex 16
ENCRYPTION_KEY="ganti_dengan_32_karakter_hex_key"

# ── SHOPEE API ────────────────────────────────────────────────
# Ambil dari Shopee Open Platform: https://open.shopee.com
SHOPEE_PARTNER_ID="your_partner_id"
SHOPEE_PARTNER_KEY="your_partner_key"

# Shopee API base URL
# Production: https://partner.shopeemobile.com
# Sandbox:    https://partner.test-stable.shopeemobile.com
SHOPEE_BASE_URL="https://partner.shopeemobile.com"

# ── TIKTOK SHOP API ───────────────────────────────────────────
# Ambil dari TikTok Shop Partner Center
TIKTOK_APP_KEY="your_tiktok_app_key"
TIKTOK_APP_SECRET="your_tiktok_app_secret"

# TikTok API base URL
TIKTOK_BASE_URL="https://open-api.tiktokglobalshop.com"
TIKTOK_AUTH_URL="https://services.tiktokshop.com/open/authorize"
TIKTOK_TOKEN_URL=""
OAUTH_STATE_SECRET="" # opsional, fallback ke NEXTAUTH_SECRET bila kosong

# ── NODE ──────────────────────────────────────────────────────
NODE_ENV="development"  # production di EasyPanel
